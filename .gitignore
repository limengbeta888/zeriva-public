# ==================================================
# Xcode
# ==================================================
build/
*.ipa
*.dSYM.zip
DerivedData/

# Certificates (NEVER commit these — use Match)
*.p12
*.p8
*.cer
*.mobileprovision

# Per-user Xcode data (should NOT be committed)
*.xcuserdata/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/project.xcworkspace/xcuserdata/

# Xcode user state
*.xcuserstate

# Xcode SCM / checkout metadata
*.xccheckout
*.xcscmblueprint

# Keep shared Xcode data (schemes, CI, etc.)
!*.xcodeproj/xcshareddata/
!*.xcworkspace/xcshareddata/

# SwiftUI previews
*.preview-thumbnails/

# ==================================================
# Swift Package Manager
# ==================================================
.build/
Packages/

# Commit or ignore based on team preference
Package.resolved

